---
interface Props {
  eyebrow: string;
  title: string;
  italic?: string;
  index?: string;
}

const { eyebrow, title, italic, index = '' } = Astro.props;
---

<header class="sh">
  <div class="sh__meta">
    {index && <span class="sh__index">{index}</span>}
    <span class="eyebrow" data-reveal>{eyebrow}</span>
  </div>
  <h2 class="sh__title display" data-reveal-words>
    {title}
    {italic && <span class="italic"> {italic}</span>}
  </h2>
</header>

<style>
  .sh {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-bottom: clamp(3rem, 6vw, 5rem);
    max-width: 1100px;
  }

  .sh__meta {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .sh__index {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-faint);
  }

  .sh__title {
    font-size: clamp(2.5rem, 5.6vw, 4.25rem);
    font-weight: 700;
    letter-spacing: -0.045em;
    line-height: 1.08;
  }

  .sh__title .italic {
    font-family: var(--font-display);
    font-style: normal;
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .sh {
      gap: 0.9rem;
      margin-bottom: 2.5rem;
    }

    .sh__meta {
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .sh__title {
      font-size: clamp(2.15rem, 12vw, 3.25rem);
      line-height: 0.98;
    }
  }
</style>
