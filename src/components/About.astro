---
import resume from '../data/resume.json';
import SectionHeading from './SectionHeading.astro';

const stats = [
  { value: '3+', label: 'Years coding' },
  { value: '5', label: 'Shipped projects' },
  { value: '6', label: 'Skill domains' },
  { value: '4', label: 'Certifications' },
];
---

<section id="about" class="about">
  <div class="container">
    <SectionHeading
      index="01 —"
      eyebrow="About"
      title="A builder with"
      italic="a product mindset."
    />

    <div class="about__grid">
      <div class="about__prose">
        {resume.about.map((p, i) => (
          <p data-reveal style={`--reveal-delay: ${i * 120}ms`}>
            {p}
          </p>
        ))}

        <p class="about__traits" data-reveal>
          <span class="eyebrow">How I work</span>
          Curious · Structured · Collaborative · Detail-oriented
        </p>
      </div>

      <aside class="about__side">
        <div class="about__portrait" data-reveal>
          <img src={resume.personal.profileImage} alt={resume.personal.name} loading="lazy" />
          <div class="about__portrait-frame" aria-hidden="true"></div>
        </div>

        <dl class="about__stats">
          {stats.map((s, i) => (
            <div class="stat" data-reveal style={`--reveal-delay: ${200 + i * 80}ms`}>
              <dt class="stat__v display">{s.value}</dt>
              <dd class="stat__l">{s.label}</dd>
            </div>
          ))}
        </dl>
      </aside>
    </div>
  </div>
</section>

<style>
  .about__grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(3rem, 6vw, 6rem);
    align-items: start;
  }

  .about__prose p {
    font-size: clamp(1.125rem, 1.35vw, 1.375rem);
    line-height: 1.55;
    color: var(--text);
    max-width: 52ch;
    margin: 0 0 1.5rem;
  }

  .about__prose p:last-of-type {
    color: var(--text-muted);
  }

  .about__traits {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.9rem;
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    font-size: 0.95rem;
    color: var(--text-muted);
  }

  .about__traits .eyebrow {
    flex-shrink: 0;
  }

  .about__side {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    position: sticky;
    top: 7rem;
  }

  .about__portrait {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: 24px;
    overflow: hidden;
    transform: rotate(-1.5deg);
    transition: transform 0.6s var(--ease-spring);
  }
  .about__portrait:hover {
    transform: rotate(0deg) scale(1.02);
  }
  .about__portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.9) contrast(1.05);
  }
  .about__portrait-frame {
    position: absolute;
    inset: 0;
    border: 1px solid var(--border);
    border-radius: 24px;
    pointer-events: none;
    box-shadow: inset 0 0 0 12px color-mix(in oklab, var(--bg) 55%, transparent);
  }

  .about__stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    margin: 0;
  }

  .stat {
    padding: 1.5rem;
    background: var(--bg);
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .stat__v {
    font-size: 2.25rem;
    color: var(--text);
    background: var(--accent-grad);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    font-family: var(--font-display);
  }

  .stat__l {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0;
  }

  @media (max-width: 860px) {
    .about__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .about__side {
      position: static;
      order: -1;
      gap: 1.25rem;
    }
    .about__portrait {
      max-width: min(100%, 26rem);
      margin-inline: auto;
      transform: none;
    }
    .about__stats {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 640px) {
    .about__prose p {
      max-width: 34ch;
      font-size: 1rem;
      margin-bottom: 1.1rem;
    }

    .about__traits {
      margin-top: 1.75rem;
      padding-top: 1.25rem;
      gap: 0.65rem;
      font-size: 0.9rem;
    }

    .about__stats {
      grid-template-columns: repeat(2, 1fr);
    }

    .stat {
      padding: 1.15rem;
    }

    .stat__v {
      font-size: 1.85rem;
    }
  }
</style>
