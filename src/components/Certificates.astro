---
import resume from '../data/resume.json';
import SectionHeading from './SectionHeading.astro';
---

<section id="certificates" class="ct">
  <div class="container">
    <SectionHeading
      index="06 —"
      eyebrow="Certifications"
      title="Proof of"
      italic="continued learning."
    />

    <div class="ct__grid">
      {resume.certifications.map((c, i) => (
        <a
          class="ct__card"
          href={c.url}
          target="_blank"
          rel="noopener"
          data-reveal
          style={`--reveal-delay: ${i * 80}ms`}
        >
          <div class="ct__issuer">{c.issuer}</div>
          <h3 class="ct__title">{c.title}</h3>
          <div class="ct__foot">
            <span>View credential</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 17L17 7M9 7h8v8" />
            </svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .ct__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  @media (max-width: 900px) {
    .ct__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 540px) {
    .ct__grid {
      grid-template-columns: 1fr;
    }
  }

  .ct__card {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2rem;
    padding: 1.75rem;
    min-height: 230px;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 20px;
    overflow: hidden;
    isolation: isolate;
    transition: transform 0.4s var(--ease-out-quart), border-color 0.4s var(--ease-out-quart);
  }

  .ct__card::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(140deg, color-mix(in oklab, var(--accent) 12%, transparent), transparent 60%);
    opacity: 0;
    transition: opacity 0.5s var(--ease-out-quart);
  }

  .ct__card:hover {
    transform: translateY(-4px);
    border-color: var(--border-strong);
  }

  .ct__card:hover::before {
    opacity: 1;
  }

  .ct__issuer {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .ct__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.5rem;
    letter-spacing: -0.01em;
    line-height: 1.15;
    margin: 0;
  }

  .ct__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    transition: color 0.3s var(--ease-out-quart);
  }

  .ct__card:hover .ct__foot {
    color: var(--text);
  }

  .ct__foot svg {
    transition: transform 0.3s var(--ease-spring);
  }

  .ct__card:hover .ct__foot svg {
    transform: translate(2px, -2px);
  }
</style>
